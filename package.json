{
  "name": "cbsd-task-management-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:feature-x": "turbo run dev --filter=feature-x",
    "dev:feature-y": "turbo run dev --filter=feature-y",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "clean": "turbo run clean && rm -rf node_modules/.cache .turbo"
  },
  "devDependencies": {
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "prettier": "^3.8.4",
    "@types/node": "^25.9.2"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18"
  }
}
